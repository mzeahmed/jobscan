###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_a_random_32_char_string
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# SQLite (défaut — aucune installation requise)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/jobscan.db"

# PostgreSQL (optionnel)
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/jobscan?serverVersion=16&charset=utf8"

# MySQL / MariaDB (optionnel)
# DATABASE_URL="mysql://user:password@127.0.0.1:3306/jobscan?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> searxng ###
# Instance SearXNG locale (Docker recommandé)
# docker run -d -p 8080:8080 searxng/searxng
SEARXNG_URL='https://searxng.local:8443/'
###< searxng ###

###> ai-provider ###
# Le moteur LLM actif ("ollama", "lmstudio" ou "gemini") se choisit dans
# config/packages/jobscan.yaml (clé jobscan.llm.provider), pas ici. Voir
# LLMClientFactory pour en ajouter d'autres (Claude, OpenAI, ...).
#
# Les variables ci-dessous alimentent uniquement base_url/model/api_key de
# chaque provider dans jobscan.llm.*, quel que soit celui actif.

# ── Ollama (recommandé par défaut) ──
# Installation : https://ollama.com
#   ollama pull qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b

# Si Symfony tourne dans Docker et Ollama sur l'hôte :
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ── Legacy provider : LM Studio (conservé pour compatibilité, non recommandé) ──
# Démarrer LM Studio → charger un modèle → activer le serveur local (port 1234)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# ── Gemini (jobscan.llm.provider: gemini) ──
# Clé d'API : https://aistudio.google.com/api-keys?hl=fr
GEMINI_API_KEY='my-gemini-api-key'
GEMINI_MODEL=gemini-2.0-flash
###< ai-provider ###

###> telegram ###
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Récupérer l'ID de votre chat via @userinfobot ou l'API Telegram
TELEGRAM_CHAT_ID=123456789
###< telegram ###

###> rss-feeds ###
# Flux RSS d'offres d'emploi — ajouter autant que nécessaire
JOB_FEED_URL_1=https://remoteok.com/remote-dev-jobs.rss
JOB_FEED_URL_2=https://www.reddit.com/r/forhire/.rss
# JOB_FEED_URL_3=https://weworkremotely.com/categories/remote-programming-jobs.rss
###< rss-feeds ###

###> jobscan-profile ###
# Profil métier — listes séparées par des virgules, sans espace après la virgule.
# Adapter à un autre profil technique (ex : Python/Django) sans toucher au code.
FILTER_KEYWORDS=php,symfony,wordpress,backend,fullstack,api
KNOWN_STACK=php,symfony,wordpress,mysql,postgresql,redis,docker,react,vue,api,rabbitmq,laravel,typescript,javascript
SEARX_QUERIES="php symfony remote job,php symfony freelance remote,wordpress php remote developer,backend php api remote job,développeur php,développeur php symfony full remote,développeur php WordPress,mission developeur php,mission freelance php symfony remote"
JOB_LOCATIONS="Marseille,Paris,Aix-en-Provence,Ile-de-France,Bouches-du-Rhône,Provence-Alpes-Côte d'Azur,Remote"
###< jobscan-profile ###
